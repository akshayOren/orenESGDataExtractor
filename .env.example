# Copy this file to .env and fill in real values. Never commit .env.

# --- Pipeline behaviour ---
LOG_LEVEL=INFO
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
LOG_DIR=logs

# --- Source credentials ---
ESG_API_KEY=your_api_key_here
ESG_API_BASE_URL=https://api.example.com/v1

# --- Destination (PostgreSQL example) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=esg_data
DB_USER=your_db_user
DB_PASSWORD=your_db_password
