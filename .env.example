# Copy this file to .env and fill in real values. Never commit .env.

# --- Pipeline behaviour ---
LOG_LEVEL=INFO
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
LOG_DIR=logs
REPORT_SCAN_DIR=data/reports/uae

# --- Source credentials ---
ESG_API_KEY=your_api_key_here
ESG_API_BASE_URL=https://api.example.com/v1
ANTHROPIC_API_KEY='your_anthropic_api_key_here'

# --- Google Gemini (used for Vision/chart extraction — cheaper than Claude Vision) ---
# Get a key from https://aistudio.google.com/apikey
# If not set, Vision extraction falls back to Claude Vision API.
GOOGLE_API_KEY='your_google_api_key_here'

# --- ADX API (Abu Dhabi Securities Exchange) ---
# Copy the Cookie header value from DevTools on a successful ADX API request.
# DevTools → Network → the sustainability API call → Request Headers → Cookie
ADX_COOKIE=

# --- Destination (PostgreSQL example) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=esg_data
DB_USER=your_db_user
DB_PASSWORD=your_db_password
